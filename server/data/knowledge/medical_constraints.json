        "modifications": ["avoid breath holding during lifts", "keep intensity moderate", "monitor heart rate"],
        "notes": "Target 60-70% max heart rate. Avoid overhead pressing with very heavy weights."
      },
      "yoga": {
        "avoid": ["full_inversions_headstand_shoulderstand", "breath_retention_kumbhaka", "kapalbhati_aggressive"],
        "prefer": ["gentle_yoga", "savasana", "yoga_nidra", "nadi_shodhana", "meditation"],
        "beneficial_poses": ["sukhasana", "viparita_karani_legs_up_wall", "balasana", "savasana"]
      },
      "diet": {
        "avoid": ["excess_salt", "processed_foods", "caffeine_excess", "alcohol", "pickles", "papad"],
        "prefer": ["potassium_rich_foods", "bananas", "leafy_greens", "beetroot", "garlic", "omega3"],
        "modifications": ["DASH_diet_principles", "reduce_sodium_below_2300mg"],
