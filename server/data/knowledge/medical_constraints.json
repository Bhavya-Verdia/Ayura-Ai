{
  "constraints": {
    "diabetes_type2": {
      "description": "Type 2 Diabetes Mellitus — requires blood sugar management",
      "gym": {
        "avoid": ["prolonged_fasting_workouts", "extremely_high_intensity_without_snack"],
        "prefer": ["moderate_cardio", "resistance_training", "post_meal_walking"],
        "modifications": ["carry glucose tablets", "monitor blood sugar before/after", "stay hydrated"],
        "notes": "Resistance training improves insulin sensitivity. Avoid exercising if blood sugar > 250 mg/dL or < 70 mg/dL."
      },
      "yoga": {
        "avoid": ["prolonged_inversions_unsupervised", "extreme_hot_yoga"],
        "prefer": ["gentle_flow", "restorative", "pranayama", "surya_namaskar_modified"],
        "modifications": ["keep sessions under 45 min initially"],
        "beneficial_poses": ["dhanurasana", "ardha_matsyendrasana", "paschimottanasana", "mandukasana"]
      },
      "diet": {
        "avoid": ["high_gi_foods", "excess_fruit_juice", "white_rice_large_portions", "refined_sugar", "processed_foods"],
        "prefer": ["low_glycemic_meals", "high_fiber", "whole_grains", "bitter_gourd", "fenugreek", "cinnamon"],
        "modifications": ["small_frequent_meals", "complex_carbs_only", "monitor_portion_sizes"],
        "calorie_adjustment": "no specific reduction unless also overweight"
      },
      "panchakarma": {
        "avoid": ["vamana_unsupervised", "strong_virechana"],
        "prefer": ["gentle_basti", "abhyanga_with_sesame_oil", "udwarthana_dry_powder_massage"],
        "notes": "Panchakarma should be done under supervision. Udwarthana is particularly beneficial for metabolic conditions."
      },
      "remedies": {
        "avoid": ["honey_in_large_amounts_heated", "excessive_sweet_herbs"],
        "prefer": ["fenugreek_water", "bitter_gourd_juice", "turmeric_milk", "amla", "jamun_seeds"],
        "herb_interactions": ["fenugreek may enhance blood sugar lowering — monitor closely"]
      }
    },
