# Auto-detect text files and normalize to LF on commit
* text=auto eol=lf

# Force LF for all common source file types
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.sql text eol=lf
*.env text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
*.txt text eol=lf

# Dockerfiles
Dockerfile text eol=lf

# Binaries — no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pkl binary
*.joblib binary
*.db binary
