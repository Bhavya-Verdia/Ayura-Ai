# Ayura AI — Staging env. Copy to .env.staging and fill in.
#   cp .env.staging.example .env.staging
# Generate the three secrets with:  openssl rand -hex 32
# Infra URLs (Mongo/Redis/Chroma) are injected by docker-compose.staging.yml — don't set them here.

# Keep staging out of strict production mode (avoids HTTPS-only cookies locally).
APP_ENV=staging
DEBUG=false

# ── Secrets (REQUIRED — generate unique values) ──
SECRET_KEY=__run: openssl rand -hex 32__
JWT_SECRET_KEY=__run: openssl rand -hex 32__
ADMIN_TOKEN=__run: openssl rand -hex 32__

# ── LLM (at least one provider REQUIRED for diet/chat/seasonal/dosha narrative) ──
# Gemini alone is enough to run the app.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# ── Frontend origin (CORS + OAuth redirects) ──
FRONTEND_URL=http://localhost:8080

# ── Optional: email delivery (verification + reminder/notification emails) ──
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=

# ── Optional: OAuth (leave blank to use email/password only) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Optional: LangSmith tracing ──
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ayura-staging
LANGSMITH_TRACING=false
