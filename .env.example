# =============================================
# Ayura AI — Environment Variables
# Copy this file to .env and fill in your values.
# The server reads both server/.env and the root .env.
# =============================================

# --- App ---
APP_NAME=Ayura AI
APP_ENV=development          # development | production
DEBUG=true
SECRET_KEY=change-me-in-production
ADMIN_TOKEN=change-this-admin-token
PLAN_TIMEOUT_SECONDS=120

# --- MongoDB ---
# Either set MONGO_URL directly, or set the individual parts below.
# MONGO_URL=mongodb://user:password@host:27017/ayura?authSource=admin
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=ayura
# MONGO_USER=
# MONGO_PASSWORD=

# --- Redis (required for background worker and rate limiting) ---
REDIS_URL=redis://localhost:6379/0

# --- ChromaDB ---
# Leave CHROMA_HOST unset to use embedded local storage (dev default).
# CHROMA_HOST=localhost
CHROMA_PORT=8001
# CHROMA_PERSIST_DIRECTORY=server/data/chromadb  # default

# --- LLM: Azure OpenAI (primary) ---
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# --- LLM: Google Gemini (fallback — app works with only this set) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- LangSmith tracing (optional — observability for the LangGraph health agent) ---
# Leave LANGSMITH_API_KEY blank to disable tracing entirely (zero overhead).
# Set it (get a key at https://smith.langchain.com) to trace every agent run,
# tool call, and token in the LangSmith dashboard.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ayura-health-agent
LANGSMITH_TRACING=true

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback  # derived from FRONTEND_URL if unset

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
# COOKIE_SECURE=false    # auto-forced true in production
# COOKIE_SAMESITE=lax    # auto-forced strict in production

# --- Weather (optional — OpenWeatherMap free tier) ---
# WEATHER_API_KEY=

# --- Sentry Error Tracking (optional) ---
# SENTRY_DSN=

# --- File Uploads ---
# Local uploads directory is used when S3 vars are unset.
# UPLOADS_DIR=server/uploads
# S3_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_REGION_NAME=
# S3_ENDPOINT_URL=    # for R2 / Spaces / MinIO

# --- Email / SMTP (for verification & password reset) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@ayura.com

# --- SMS / OTP ---
SMS_OTP_MOCK=true          # set false in production with Twilio configured
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# --- URLs ---
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
# FRONTEND_URLS=https://yourdomain.com,https://www.yourdomain.com   # comma-separated extra origins
# TRUSTED_HOSTS=yourdomain.com,www.yourdomain.com

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
AUTH_RATE_LIMIT_PER_MINUTE=20

# =============================================
# Frontend (Vite) — prefix with VITE_
# These are read by client/vite.config.js from the root .env.
# =============================================
# VITE_API_URL=/api    # defaults to /api (proxied by Vite dev server)
